#!/usr/bin/env bash
# direnv configuration for smartfo

# Include shared environment setup
# Boilerplate Shared Partials Environment Configuration
# This file sets up the development environment for the boilerplate shared partials system

# 1. Install Nix if necessary
# 2. Use Nix to install devbox if necessary  
# 3. Use Devbox shell
# 4. Set up boilerplate-specific environment

# FIRST: Exit existing devbox shell if we're in one (prevents shell inception)
if [[ "$DEVBOX_SHELL_ENABLED" == "1" ]]; then
    echo "🔄 Exiting existing devbox shell to prevent shell inception..."
    exit 0
fi

# Helper functions to modify PATH idempotently
path_prepend() {
  local p="$1"
  if [ -d "$p" ] && [[ ":$PATH:" != *":$p:"* ]]; then
    export PATH="$p:$PATH"
  fi
}

path_append() {
  local p="$1"
  if [ -d "$p" ] && [[ ":$PATH:" != *":$p:"* ]]; then
    export PATH="$PATH:$p"
  fi
}

# Ensure nix profile bin is on PATH for direnv hooks
# 1. Clean install (multi-user default) -> First priority
path_append "/nix/var/nix/profiles/default/bin"

# System paths - ensure basic tools are available
# 2. Standard system paths
path_append "/usr/local/bin"
path_append "/usr/bin"
path_append "/bin"

# 3. User profile (often used by system package manager installs or single-user) -> Last priority
if ! command -v nix >/dev/null 2>&1; then
    path_prepend "$HOME/.nix-profile/bin"
fi

# 4. User local binaries (Homebrew, local installs)
path_prepend "$HOME/.local/bin"
path_prepend "$HOME/bin"

# Install Nix if not available
if ! command -v nix-shell >/dev/null 2>&1; then
    echo "⚠️ Nix not found. Installing Nix..."
    curl -L https://nixos.org/nix/install | sh
fi

# Ensure devbox is available
if ! command -v devbox >/dev/null 2>&1; then
    if [ -d "$HOME/.nix-profile/bin" ]; then
        path_append "$HOME/.nix-profile/bin"
    fi
fi

if ! command -v devbox >/dev/null 2>&1; then
    echo "⚠️ Devbox not found. Installing via Nix..."
    nix profile install nixpkgs/nixpkgs-unstable#devbox
    if [ -d "$HOME/.nix-profile/bin" ]; then
        path_append "$HOME/.nix-profile/bin"
    fi
fi

# Verify devbox is available
if ! command -v devbox >/dev/null 2>&1; then
    echo "❌ Devbox installation failed or binary not found in PATH." >&2
    exit 1
fi

use_devbox() {
    watch_file devbox.json
    eval "$(devbox shellenv)"
}

if command -v devbox >/dev/null 2>&1; then
    use devbox
fi

# Add boilerplate root to PATH for easy access to copier-wrapper
export BOILERPLATE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PATH="$BOILERPLATE_ROOT:$PATH"

# Ensure copier is available
if ! command -v copier >/dev/null 2>&1; then
    echo "⚠️  Warning: copier not found in PATH. Please install copier:"
    echo "   pip install copier"
    echo "   Or use your package manager (npm, brew, etc.)"
fi

# Set up Python environment for template processing
if command -v python3 >/dev/null 2>&1; then
    export PYTHONPATH="$BOILERPLATE_ROOT:$PYTHONPATH"
fi

# Enable debug mode for wrapper script if requested
if [[ "${BOILERPLATE_DEBUG}" == "1" ]]; then
    export COPIER_DEBUG=1
    echo "🐛 Boilerplate debug mode enabled"
fi

echo "🔧 Boilerplate shared environment initialized"
echo "📁 Boilerplate root: $BOILERPLATE_ROOT"
echo "🛠️  Use: copier-wrapper.sh copy <template> <destination>"




# Project-specific additions
if [ -f "/.envrc" ]; then
    direnv allow ""
fi
