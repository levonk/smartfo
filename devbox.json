{
  "name": "smartfo",
  "version": "0.1.0",
  "description": "A Rust CLI application",
  "packages": {
    "rustc": "",
    "cargo": "",
    "rust-analyzer": "",
    "clippy": "",
    "rustfmt": "",
    "just": "",
    "cargo-watch": "",
    "cargo-tarpaulin": "",
    "cargo-audit": "",
    "pkg-config": "",
    "github:levonk/levonk-packages#devbox-rtk-nodejs-pnpm-force": "",
    "github:levonk/levonk-packages#devbox-rtk-python-uv-force": "",
    "github:levonk/levonk-packages#bundle-rtk-core": "",
    "github:levonk/levonk-packages#bundle-rtk-cloud": "",
    "github:levonk/smartfo": "",
    "sqlite": ""
  },
  "shell": {
    "init_hook": [
      "just bootstrap-internal"
    ]
  },
  "scripts": {
    "bootstrap": "just bootstrap-internal",
    "doctor": "just doctor-internal",
    "clean": "just clean-internal",
    "build": "just build-internal",
    "lint": "just lint-internal",
    "test": "just test-internal",
    "typecheck": "just typecheck-internal",
    "dev": "just dev-internal",
    "debug": "just debug-internal",
    "install": "just install-internal",
    "release": "just release-internal"
  },
  "env": {
    "RUST_LOG": "info",
    "RUST_BACKTRACE": "1",
    "DATABASE_URL": "sqlite:./smartfo.db"
  },
  "hooks": {
    "on_create": [
      "cargo fetch"
    ]
  }
}
